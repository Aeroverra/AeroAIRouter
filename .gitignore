# ── Dependencies ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# ── Secrets & credentials ─────────────────────────────────────
# These live in AIROUTER_HOME (~/.aeroairouter), never in the repo. Listed here
# as a backstop against accidental commits if files are copied into the tree.
secrets.env
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt

# ── Runtime data & user content (kept in AIROUTER_HOME) ───────
data/
workspace/
credentials/
# Real persona files are private; the *.example.md templates are committed.
persona/*.md
!persona/*.example.md

# ── Backups, logs, pids ───────────────────────────────────────
*.bak
*.bak.*
*.orig
*.log
*.pid

# ── OS / editor noise ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~

# ── Test / coverage artifacts ─────────────────────────────────
coverage/
.nyc_output/

# ── Local planning / scratch ──────────────────────────────────
PLAN.md
_*.mjs
_*.cjs

# UI build sourcemaps (the bundle itself IS committed)
src/ui/public/app.js.map
src/ui/public/app.css.map
