# AeroAIRouter secrets — copy to $AIROUTER_HOME/secrets.env (default ~/.aeroairouter/secrets.env)
# and chmod 600. NEVER commit the real file. Real environment variables override these.

# --- Discord (required) ---
DISCORD_TOKEN=

# --- Claude auth: set AT LEAST ONE. Choose during setup. ---
# Option 1 (default, recommended): standard Anthropic API key.
ANTHROPIC_API_KEY=
# Option 2: Claude subscription via a long-lived OAuth setup-token
#   (generate with: claude setup-token). Equal, first-class option.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Optional integrations ---
# Brave Search API key — enables the web_search tool. Leave blank to disable.
BRAVE_API_KEY=
